# Server Configuration
NODE_ENV=development
PORT=5000
SERVER_URL=http://localhost:5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ghn_meeting_room_booking
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email Configuration (API-based)
EMAIL_API_KEY=your_email_service_api_key
EMAIL_API_URL=https://your-email-service.com/api/send
EMAIL_FROM=noreply@ghn.vn
COMPANY_DOMAIN=ghn.vn

# Features
AUTO_CHECKIN_TIMEOUT_MINUTES=15
MAX_BOOKING_DURATION_HOURS=4
BOOKING_WINDOW_DAYS=30

# Logging
LOG_LEVEL=debug
